{
  "appId": "com.tanmaychavan.focusblocker",
  "productName": "Focus Blocker",
  "files": ["dist-electron", "dist-react"],
  "asar": true,
  "asarUnpack": ["dist-electron/**", "node_modules/node-windows/**"],
  "extraResources": ["dist-electron/electron/preload.cjs", "src/assets/**"],
  "icon": "./desktopIcon.png",
  "mac": {
    "target": "dmg"
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility"
  },
  "win": {
    "target": ["nsis"]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "include": "build/installer.nsh"
  }
}
